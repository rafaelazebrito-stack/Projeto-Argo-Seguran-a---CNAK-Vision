import random
import time
class HeatmapPro:
    def __init__(self, edificios=4, capacidade_diaria=5000):
        self.edificios = edificios
        self.capacidade_diaria = capacidade_diaria
        self.dados_fluxo = []

    def monitorar_fluxo(self):
        """Simula captura de fluxo de pessoas"""
        fluxo = random.randint(1000, self.capacidade_diaria)
        self.dados_fluxo.append(fluxo)
        print(f"Fluxo monitorado: {fluxo} pessoas")

    def gerar_mapa_calor(self):
        """Gera zonas quentes/frias com base no fluxo"""
        zonas = {
            "Zona A": random.randint(50, 500),
            "Zona B": random.randint(100, 800),
            "Zona C": random.randint(200, 1000)
        }
        print("Mapa de calor gerado:", zonas)
        return zonas

    def analisar_retencao_vitrine(self):
        """Calcula tempo médio de permanência em vitrines"""
        tempos = [random.randint(5, 120) for _ in range(10)]  # segundos
        media = sum(tempos) / len(tempos)
        print(f"Tempo médio de retenção: {media:.2f} segundos")
        return media

    def definir_alocacao_estrategica(self, zonas):
        """Sugere decisão baseada em dados"""
        zona_mais_movimentada = max(zonas, key=zonas.get)
        print(f"Alocação estratégica: reforçar equipe na {zona_mais_movimentada}")

    def visualizar_dashboard(self):
        """Exibe resumo dos dados coletados"""
        print("=== Dashboard BI ===")
        print(f"Edifícios monitorados: {self.edificios}")
        print(f"Capacidade diária: {self.capacidade_diaria}")
        print(f"Fluxos registrados: {self.dados_fluxo}")

    def gerenciar_usuarios(self, usuarios):
        """Simula gestão de usuários"""
        print("Usuários cadastrados no sistema:", usuarios)


# Exemplo de execução
if __name__ == "__main__":
    sistema = HeatmapPro()
    sistema.monitorar_fluxo()
    zonas = sistema.gerar_mapa_calor()
    sistema.analisar_retencao_vitrine()
    sistema.definir_alocacao_estrategica(zonas)
    sistema.visualizar_dashboard()
    sistema.gerenciar_usuarios(["Lojista A", "Administrador CNAK"])